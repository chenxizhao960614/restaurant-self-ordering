PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
# Must match the database where you ran schema.sql (on Aiven create DB "restaurant_ordering" and set DB_NAME to that, not defaultdb)
DB_NAME=restaurant_ordering
# Optional: fail fast if DB is unreachable (ms)
# DB_CONNECT_TIMEOUT_MS=15000
# Aiven / cloud MySQL: auto-enabled when DB_HOST contains aivencloud.com.
# Aiven without CA file: app defaults to TLS with relaxed cert check on aivencloud.com hosts.
# Stricter: add Aiven CA → DB_SSL_CA_PATH=./aiven-ca.pem, or set DB_SSL_REJECT_UNAUTHORIZED=1
# DB_SSL=true
# DB_SSL_CA_PATH=./aiven-ca.pem
# DB_SSL_REJECT_UNAUTHORIZED=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
